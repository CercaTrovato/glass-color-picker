{
  "name": "glass-color-picker",
  "private": true,
  "version": "0.1.0",
  "description": "A desktop and web image color picker with magnifier sampling and palette suggestions.",
  "author": "CercaTrovato",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "desktop": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:3000 && cross-env ELECTRON_START_URL=http://127.0.0.1:3000 electron .\"",
    "build": "vite build",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win nsis portable",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.cercatrovato.glasscolorpicker",
    "productName": "Glass Color Picker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
